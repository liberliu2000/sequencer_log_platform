APP_NAME=Sequencer Log Platform
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

DATABASE_URL=sqlite:///./data/sequencer_log_platform.db
MAX_UPLOAD_MB=512
DEFAULT_TIME_ROUNDING=truncate

LLM_ENABLED=false
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_api_key_here
LLM_MODEL=ep-xxxx
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=3
